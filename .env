# ══════════════════════════════════════════════════════════════════════════════
#  LOCAL DEVELOPMENT  — loaded automatically when NODE_ENV is not 'production'
#  Run:  npm run dev
# ══════════════════════════════════════════════════════════════════════════════

# ─── Server ───────────────────────────────────────────────────────────────────
PORT=3000
JWT_SECRET=local-dev-secret-not-for-production
DB_PATH=./db/menuqr.db

# ─── URLs ─────────────────────────────────────────────────────────────────────
FRONTEND_URL=http://localhost:5173
# BASE_URL auto-detects your LAN IP so phones on the same Wi-Fi can scan QR codes

# ─── Resend (email) ───────────────────────────────────────────────────────────
# 1. Go to https://resend.com  →  sign up free (3 000 emails/month free)
# 2. Dashboard → API Keys → Create API Key
# 3. Paste it below
#
# WITHOUT a verified domain the FROM address is locked to onboarding@resend.dev
# but emails still reach real inboxes — perfect for local testing.
# Verify your domain later to send from noreply@yourdomain.com
#
RESEND_API_KEY=re_MDUwGBXv_QFYMNACLjLizbBEYxuARfkw2
EMAIL_FROM=MenuQR <onboarding@resend.dev>

# All dev emails are redirected to this address (your Resend account email)
# so Resend's "unverified domain" restriction never blocks you locally.
RESEND_TEST_EMAIL=piyushrai558@gmail.com

# ─── Razorpay TEST keys ───────────────────────────────────────────────────────
# 1. Go to https://razorpay.com  →  sign up  →  Dashboard
# 2. Settings → API Keys → Generate Test Key
# 3. Paste Key ID and Key Secret below
#
# Test card:  4111 1111 1111 1111  |  any future expiry  |  CVV: any 3 digits
# OTP prompt: enter  1234
#
RAZORPAY_KEY_ID=rzp_test_PASTE_KEY_ID_HERE
RAZORPAY_KEY_SECRET=PASTE_KEY_SECRET_HERE
