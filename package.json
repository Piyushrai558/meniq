{
  "name": "menuqr-fullstack",
  "version": "1.0.0",
  "private": true,
  "description": "MenuQR — Digital Menus for Restaurants (React + Node.js + SQLite)",
  "scripts": {
    "dev": "concurrently \"npm run server\" \"npm run client\"",
    "server": "node server/index.js",
    "client": "cd client && npm run dev",
    "build": "cd client && npm run build",
    "start": "npm run build && node server/index.js",
    "seed": "node server/seed.js",
    "install:all": "npm install && cd client && npm install"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "better-sqlite3": "^9.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "jsonwebtoken": "^9.0.2",
    "multer": "^2.0.0",
    "qrcode": "^1.5.3",
    "razorpay": "^2.9.2",
    "resend": "^6.4.2"
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  }
}
